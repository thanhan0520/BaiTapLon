@model IEnumerable<PhongBan>
@{
    ViewData["Title"] = "Quan li phong ban";
    Layout = "~/Areas/Administrator/Views/Shared/_Layout.cshtml";
}
<div class="pagetitle">
    <h1>Phong ban</h1>
</div>

<section class="section">
    <a href="/Phongban/Create" class="btn btn-primary">
        Them moi
    </a>
    <table class="table table-bordered table-hover mt-2">
        <tr>
            <th>Id</th>
            <th>Ho ten</th>
            @* <th>So dien thoai</th> *@
            <th>Hanh dong</th>
        </tr>
        @foreach(var item in Model)
        {
            <tr>
                <td>@item.MaPb</td>
                <td>@item.TenPb</td>
                <td>
                    <a class="btn btn-warning" href="/PhongBan/Edit/@item.MaPb">Sua</a>
                    <a class="btn btn-warning" href="/PhongBan/Edit/@item.MaPb">Xoa</a>

                </td>
            </tr>
        }
    </table>
</section>
