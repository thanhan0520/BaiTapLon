@model A_D.Models.Cart

@{
    ViewData["Title"] = "Giỏ hàng";
}

<style>
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fafc);
    }

    .cart-wrapper {
        max-width: 1200px;
        margin: auto;
    }

    .cart-card {
        border-radius: 20px;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .cart-card:hover {
            transform: translateY(-3px);
        }

    .cart-img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 12px;
        border: 2px solid #f1f5f9;
    }

    .table thead {
        background: linear-gradient(90deg, #6366f1, #4f46e5);
        color: white;
    }

    .table th {
        border: none;
        font-weight: 500;
    }

    .table td {
        border-color: #f1f5f9;
    }

    .table tbody tr {
        transition: 0.2s;
    }

        .table tbody tr:hover {
            background: #f8fafc;
            transform: scale(1.01);
        }

    .badge {
        padding: 6px 10px;
        border-radius: 10px;
        font-weight: 500;
    }

    .btn {
        border-radius: 10px;
    }

    .btn-outline-secondary:hover {
        background: #e2e8f0;
    }

    .btn-outline-primary {
        border-color: #6366f1;
        color: #6366f1;
    }

        .btn-outline-primary:hover {
            background: #6366f1;
            color: white;
        }

    .btn-outline-danger:hover {
        background: #ef4444;
        color: white;
    }

    .remove-btn {
        transition: 0.2s;
    }

        .remove-btn:hover {
            transform: scale(1.15);
        }

    .cart-total {
        font-size: 1.4rem;
    }

    .total-box {
        background: #f8fafc;
        padding: 15px 20px;
        border-radius: 12px;
    }

    .btn-checkout {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        border: none;
        padding: 10px 30px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: 0.3s;
    }

        .btn-checkout:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(34,197,94,0.4);
        }

    .empty-cart {
        padding: 60px 20px;
    }

        .empty-cart h5 {
            font-size: 1.2rem;
        }

        .empty-cart a {
            border-radius: 12px;
            padding: 10px 30px;
        }
</style>

<div class="container mt-5 cart-wrapper">
    <div class="card cart-card p-4">
        <h3 class="mb-4 fw-bold text-primary">Giỏ hàng của bạn</h3>

        @if (Model == null || !Model.CartItems.Any())
        {
            <div class="text-center empty-cart">
                <h5 class="text-muted mb-3">Giỏ hàng của bạn đang trống</h5>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    Mua sắm ngay
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle table-hover">
                    <thead class="text-center">
                        <tr>
                            <th>Ảnh</th>
                            <th>Sản phẩm</th>
                            <th>Thương hiệu</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                            <th>Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.Milk.ImagePath))
                                    {
                                        <img src="@item.Milk.ImagePath" class="cart-img" />
                                    }
                                    else
                                    {
                                        <div class="cart-img bg-light d-flex align-items-center justify-content-center">
                                            N/A
                                        </div>
                                    }
                                </td>

                                <td class="fw-semibold">@item.Milk.MilkName</td>

                                <td class="text-center">
                                    <span class="badge bg-secondary">
                                        @item.Milk.Brand
                                    </span>
                                </td>

                                <td class="text-center">
                                    @item.Milk.Price.ToString("N0") đ
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center gap-2">

                                        @if (item.Quantity > 1)
                                        {
                                            <form asp-controller="Cart" asp-action="DecreaseQuantity" method="post">
                                                <input type="hidden" name="id" value="@item.Milk.MilkId" />
                                                <button class="btn btn-outline-secondary btn-sm">-</button>
                                            </form>
                                        }

                                        <span class="fw-bold px-2">@item.Quantity</span>

                                        <form asp-controller="Cart" asp-action="IncreaseQuantity" method="post">
                                            <input type="hidden" name="id" value="@item.Milk.MilkId" />
                                            <button class="btn btn-outline-primary btn-sm">+</button>
                                        </form>

                                    </div>
                                </td>

                                <td class="text-end fw-semibold text-danger">
                                    @((item.Milk.Price * item.Quantity).ToString("N0")) đ
                                </td>

                                <td class="text-center">
                                    <form asp-controller="Cart" asp-action="RemoveFromCart" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');">
                                        <input type="hidden" name="id" value="@item.Milk.MilkId" />
                                        <button class="btn btn-outline-danger btn-sm remove-btn">
                                            Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4 flex-wrap gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    Tiếp tục mua sắm
                </a>

                <div class="text-end total-box">
                    <div class="cart-total mb-2">
                        Tổng:
                        <span class="text-danger fw-bold">
                            @Model.CartItems.Sum(i => i.Milk.Price * i.Quantity).ToString("N0") đ
                        </span>
                    </div>

                    <form asp-controller="Cart" asp-action="Checkout" method="post"
                          onsubmit="return confirm('Thanh toán thành công! Nhấn OK để hoàn tất và xóa giỏ hàng');">
                        <button class="btn btn-success btn-checkout">
                            Thanh toán
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>