<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - A_D</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/A_D.styles.css" asp-append-version="true" />

    <style>
            body {
                background: linear-gradient(135deg, #eef2ff, #f8fafc);
                font-family: 'Segoe UI', sans-serif;
            }

            .navbar {
                backdrop-filter: blur(10px);
                background: rgba(255,255,255,0.8) !important;
                border-radius: 0 0 15px 15px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            }

            .navbar-brand {
                font-weight: 700;
                font-size: 1.3rem;
                color: #4f46e5 !important;
            }

            .nav-link {
                position: relative;
                font-weight: 500;
                transition: 0.3s;
            }

                .nav-link:hover {
                    color: #4f46e5 !important;
                }

                .nav-link::after {
                    content: "";
                    position: absolute;
                    left: 0;
                    bottom: 0;
                    width: 0%;
                    height: 2px;
                    background: #4f46e5;
                    transition: 0.3s;
                }

                .nav-link:hover::after {
                    width: 100%;
                }

            .cart-icon {
                font-size: 1.3rem;
                transition: 0.3s;
            }

                .cart-icon:hover {
                    transform: scale(1.2);
                }

            .dropdown-menu {
                border-radius: 12px;
                border: none;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            }

            .dropdown-item:hover {
                background: #f1f5f9;
            }

            main {
                min-height: 70vh;
            }

            footer {
                background: white;
                border-radius: 15px 15px 0 0;
                box-shadow: 0 -4px 20px rgba(0,0,0,0.05);
                padding: 15px 0;
                margin-top: 40px;
            }

                footer a {
                    color: #4f46e5;
                    text-decoration: none;
                }

                    footer a:hover {
                        text-decoration: underline;
                    }

            .btn {
                border-radius: 10px;
            }

            .search-box input {
            border-radius: 20px;
            padding: 6px 15px;
            }
            .search-box button {
                border-radius: 20px;
            }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    A_D
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 align-items-center">

                        <li class="nav-item me-3">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Trang Chủ
                            </a>
                        </li>

                        <!-- SEARCH -->
                        <li class="nav-item w-50">
                            <form asp-controller="Home" asp-action="Search" method="get" class="d-flex">
                                <input type="text" name="keyword" class="form-control me-2"
                                       placeholder="Tìm sản phẩm..." />
                                <button class="btn btn-primary">
                                    🔍
                                </button>
                            </form>
                        </li>

                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">

                        <li class="nav-item me-3">
                            <a class="nav-link cart-icon" asp-controller="Cart" asp-action="CartView">
                                🛒
                            </a>
                        </li>

                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="profileDropdown"
                                       role="button" data-bs-toggle="dropdown">
                                    @Context.Session.GetString("UserName")
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="User" asp-action="Profile">
                                            Trang cá nhân
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="User" asp-action="Logout">
                                            Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Login">
                                    Đăng Nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Register">
                                    Đăng Ký
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">

        <!-- THÔNG BÁO TEMP DATA -->
        @if (TempData["SuccessMessage"] != null)
        {
            var msg = TempData["SuccessMessage"];
            TempData.Remove("SuccessMessage");

            <div class="alert alert-success text-center mt-3">
                @msg
            </div>
        }

        @if (TempData["FailMessage"] != null)
        {
            var msg = TempData["FailMessage"];
            TempData.Remove("FailMessage");

            <div class="alert alert-danger text-center mt-3">
                @msg
            </div>
        }

        <main role="main" class="pb-3">
            @RenderBody()
        </main>

    </div>

    <footer class="text-center text-muted">
        <div class="container">
            &copy; 2026 - A_D -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>