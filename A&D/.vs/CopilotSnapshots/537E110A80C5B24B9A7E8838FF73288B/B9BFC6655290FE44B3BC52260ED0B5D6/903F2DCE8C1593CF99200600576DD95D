<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>@ViewData["Title"] - A&D Admin Dashboard</title>
    <meta content="" name="description">
    <meta content="" name="keywords">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.0/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary-color: #4154f1;
            --primary-hover: #5969f3;
            --light-bg: #f6f9ff;
            --sidebar-bg: #fff;
            --text-dark: #012970;
            --text-muted: #899bbd;
            --border-color: #ebeef4;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: "Open Sans", sans-serif;
            background: #f6f9ff;
            color: #444444;
        }

        a {
            color: var(--primary-color);
            text-decoration: none;
        }

        a:hover {
            color: var(--primary-hover);
            text-decoration: none;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: "Nunito", sans-serif;
        }

        /* ===== Header ===== */
        .header {
            transition: all 0.5s;
            z-index: 997;
            height: 60px;
            box-shadow: 0px 2px 20px rgba(1, 41, 112, 0.1);
            background-color: #fff;
            padding-left: 20px;
            display: flex;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
        }

        .header .logo {
            display: flex;
            align-items: center;
            line-height: 1;
        }

        .header .logo img {
            max-height: 26px;
            margin-right: 6px;
        }

        .header .logo span {
            font-size: 26px;
            font-weight: 700;
            color: var(--text-dark);
            font-family: "Nunito", sans-serif;
        }

        .header .toggle-sidebar-btn {
            font-size: 32px;
            padding-left: 10px;
            cursor: pointer;
            color: var(--text-dark);
            border: none;
            background: none;
            line-height: 0;
        }

        .header .search-bar {
            min-width: 360px;
            padding: 0 20px;
            flex: 1;
            margin: 0 20px;
        }

        .header .search-form {
            width: 100%;
            display: flex;
            align-items: center;
        }

        .header .search-form input {
            border: 0;
            font-size: 14px;
            color: var(--text-dark);
            border: 1px solid rgba(1, 41, 112, 0.2);
            padding: 7px 38px 7px 8px;
            border-radius: 3px;
            transition: 0.3s;
            width: 100%;
        }

        .header .search-form input:focus {
            outline: none;
            box-shadow: 0 0 10px 0 rgba(1, 41, 112, 0.15);
            border: 1px solid rgba(1, 41, 112, 0.3);
        }

        .header .search-form button {
            border: 0;
            padding: 0;
            margin-left: -30px;
            background: none;
            color: var(--text-dark);
            cursor: pointer;
        }

        .header-nav {
            margin-left: auto;
            padding-right: 20px;
            display: flex;
            align-items: center;
            gap: 25px;
        }

        .header-nav .nav-icon {
            font-size: 22px;
            color: var(--text-dark);
            cursor: pointer;
            position: relative;
            line-height: 0;
        }

        .header-nav .nav-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            color: var(--text-dark);
        }

        .header-nav .nav-profile img {
            max-height: 36px;
            border-radius: 50%;
        }

        /* ===== Sidebar ===== */
        .sidebar {
            position: fixed;
            top: 60px;
            left: 0;
            bottom: 0;
            width: 300px;
            z-index: 996;
            transition: all 0.3s;
            padding: 20px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: #aab7cf transparent;
            box-shadow: 0px 0px 20px rgba(1, 41, 112, 0.1);
            background-color: var(--sidebar-bg);
        }

        .sidebar::-webkit-scrollbar {
            width: 5px;
            height: 8px;
            background-color: #fff;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background-color: #aab7cf;
        }

        @@media (max-width: 1199px) {
            .sidebar {
                left: -300px;
            }
        }

        .toggle-sidebar .sidebar {
            left: 0;
        }

        .sidebar-nav {
            padding: 0;
            margin: 0;
            list-style: none;
        }

        .sidebar-nav li {
            padding: 0;
            margin: 0;
            list-style: none;
        }

        .sidebar-nav .nav-item {
            margin-bottom: 5px;
        }

        .sidebar-nav .nav-heading {
            font-size: 11px;
            text-transform: uppercase;
            color: var(--text-muted);
            font-weight: 600;
            margin: 10px 0 5px 15px;
        }

        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            font-size: 15px;
            font-weight: 600;
            color: var(--primary-color);
            transition: 0.3s;
            background: var(--light-bg);
            padding: 10px 15px;
            border-radius: 4px;
            text-decoration: none;
        }

        .sidebar-nav .nav-link i {
            font-size: 16px;
            margin-right: 10px;
            color: var(--primary-color);
        }

        .sidebar-nav .nav-link.collapsed {
            color: var(--text-dark);
            background: #fff;
        }

        .sidebar-nav .nav-link.collapsed i {
            color: var(--text-muted);
        }

        .sidebar-nav .nav-link:hover,
        .sidebar-nav .nav-link.active {
            color: var(--primary-color);
            background: var(--light-bg);
        }

        .sidebar-nav .nav-link:hover i,
        .sidebar-nav .nav-link.active i {
            color: var(--primary-color);
        }

        /* ===== Main ===== */
        #main {
            margin-top: 60px;
            margin-left: 300px;
            padding: 20px 30px;
            transition: all 0.3s;
        }

        @@media (max-width: 1199px) {
            #main {
                margin-left: 0;
                padding: 20px;
            }
        }

        /* ===== Page Title ===== */
        .pagetitle {
            margin-bottom: 10px;
        }

        .pagetitle h1 {
            font-size: 24px;
            margin-bottom: 0;
            font-weight: 600;
            color: var(--text-dark);
        }

        /* ===== Card ===== */
        .card {
            margin-bottom: 30px;
            border: none;
            border-radius: 5px;
            box-shadow: 0px 0 30px rgba(1, 41, 112, 0.1);
            transition: all 0.3s;
        }

        .card:hover {
            box-shadow: 0px 0 50px rgba(1, 41, 112, 0.15);
        }

        .card-header,
        .card-footer {
            border-color: var(--border-color);
            background-color: #fff;
            color: var(--text-muted);
            padding: 15px;
        }

        .card-title {
            padding: 20px 0 15px 0;
            font-size: 18px;
            font-weight: 500;
            color: var(--text-dark);
            font-family: "Poppins", sans-serif;
        }

        .card-title span {
            color: var(--text-muted);
            font-size: 14px;
            font-weight: 400;
        }

        .card-body {
            padding: 0 20px 20px 20px;
        }

        /* ===== Alert ===== */
        .alert {
            border-radius: 10px;
            border: none;
            margin-bottom: 20px;
            animation: slideDown 0.3s ease-out;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-heading {
            font-weight: 500;
            font-family: "Poppins", sans-serif;
            font-size: 20px;
        }

        .btn-close {
            background-size: 25%;
        }

        .btn-close:focus {
            outline: 0;
            box-shadow: none;
        }

        /* ===== Table ===== */
        .table {
            background: white;
            border-radius: 5px;
            margin-top: 20px;
        }

        .table thead {
            background: #f6f6fe;
        }

        .table thead th {
            border: 0;
            font-weight: 600;
            padding: 15px;
        }

        .table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: all 0.2s;
        }

        .table tbody tr:hover {
            background-color: #f9f9f9;
        }

        .table td {
            padding: 12px 15px;
            vertical-align: middle;
        }

        /* ===== Badge ===== */
        .badge {
            border-radius: 8px;
            padding: 6px 12px;
            font-weight: 500;
            font-size: 0.85rem;
        }

        .badge-success {
            background-color: #d1e7dd;
            color: #065f46;
        }

        .badge-warning {
            background-color: #fff3cd;
            color: #664d03;
        }

        .badge-danger {
            background-color: #f8d7da;
            color: #842029;
        }

        /* ===== Form ===== */
        .form-control,
        .form-select {
            border-radius: 4px;
            border: 1px solid var(--border-color);
            padding: 8px 12px;
            font-size: 14px;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.2rem rgba(65, 84, 241, 0.25);
        }

        /* ===== Button ===== */
        .btn-primary {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
            color: white;
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
            border-color: var(--primary-hover);
            color: white;
        }

        .btn-sm {
            padding: 5px 10px;
            font-size: 0.85rem;
        }

        /* ===== Search Box ===== */
        .search-box {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-box input {
            flex: 1;
            max-width: 400px;
        }

        /* ===== Pagination ===== */
        .pagination {
            gap: 5px;
            margin-top: 20px;
        }

        .pagination .page-link {
            border-radius: 4px;
            border: 1px solid var(--border-color);
            color: var(--primary-color);
        }

        .pagination .page-link:hover {
            background-color: var(--light-bg);
            color: var(--primary-color);
        }

        .pagination .page-item.active .page-link {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }

        /* ===== Back to top button ===== */
        .back-to-top {
            position: fixed;
            visibility: hidden;
            opacity: 0;
            right: 15px;
            bottom: 15px;
            z-index: 99999;
            background: var(--primary-color);
            width: 40px;
            height: 40px;
            border-radius: 4px;
            transition: all 0.4s;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            text-decoration: none;
        }

        .back-to-top i {
            font-size: 24px;
            color: #fff;
            line-height: 0;
        }

        .back-to-top:hover {
            background: var(--primary-hover);
            color: #fff;
        }

        .back-to-top.active {
            visibility: visible;
            opacity: 1;
        }

        /* ===== Footer ===== */
        .footer {
            padding: 20px 0;
            font-size: 14px;
            transition: all 0.3s;
            border-top: 1px solid var(--border-color);
            margin-left: 300px;
        }

        @@media (max-width: 1199px) {
            .footer {
                margin-left: 0;
            }
        }

        .footer .copyright {
            text-align: center;
            color: var(--text-dark);
        }

        .footer .credits {
            padding-top: 5px;
            text-align: center;
            font-size: 13px;
            color: var(--text-dark);
        }

        @@media (max-width: 768px) {
            .header .search-bar {
                display: none;
            }

            .pagetitle h1 {
                font-size: 18px;
            }

            .search-box input {
                max-width: 100%;
            }
        }

        @@media (max-width: 480px) {
            .header {
                padding-left: 10px;
            }

            .header .toggle-sidebar-btn {
                padding-left: 0;
            }

            .header-nav {
                padding-right: 10px;
                gap: 15px;
            }

            .pagetitle h1 {
                font-size: 16px;
            }

            #main {
                padding: 15px;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Header -->
    <header id="header" class="header fixed-top d-flex align-items-center">
        <div class="d-flex align-items-center justify-content-between" style="width: 100%;">
            <div class="d-flex align-items-center">
                <a href="@Url.Action("Index", "Home", new { area = "Admin" })" class="logo d-flex align-items-center">
                    <i class="bi bi-shield-check" style="font-size: 24px; color: var(--primary-color); margin-right: 6px;"></i>
                    <span class="d-none d-lg-block">A&D Admin</span>
                </a>
                <button class="toggle-sidebar-btn" id="toggleSidebarBtn" type="button">
                    <i class="bi bi-list"></i>
                </button>
            </div>

            <div class="search-bar">
                <form class="search-form" method="POST" action="#">
                    <input type="text" name="query" placeholder="Tìm kiếm..." title="Nhập từ khóa tìm kiếm">
                    <button type="submit" title="Tìm kiếm"><i class="bi bi-search"></i></button>
                </form>
            </div>

            <nav class="header-nav ms-auto">
                <ul class="d-flex align-items-center list-unstyled" style="margin: 0;">
                    <li class="nav-item">
                        <a class="nav-profile" href="@Url.Action("Profile", "User", new { area = "" })" title="Hồ sơ">
                            <img src="https://ui-avatars.com/api/?name=Admin&background=4154f1&color=fff&size=36" alt="Profile">
                            <span class="d-none d-md-block">Admin</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-icon" href="@Url.Action("Logout", "User", new { area = "" })" title="Đăng xuất">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </header>

    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar">
        <ul class="sidebar-nav" id="sidebar-nav">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" 
                   href="@Url.Action("Index", "Home", new { area = "Admin" })">
                    <i class="bi bi-grid"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Milk" ? "active" : "")" 
                   href="@Url.Action("Index", "Milk", new { area = "Admin" })">
                    <i class="bi bi-box"></i>
                    <span>Sản phẩm</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")" 
                   href="@Url.Action("Index", "User", new { area = "Admin" })">
                    <i class="bi bi-people"></i>
                    <span>Người dùng</span>
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")" 
                   href="@Url.Action("Index", "Order", new { area = "Admin" })">
                    <i class="bi bi-cart"></i>
                    <span>Đơn hàng</span>
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main id="main" class="main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <!-- Footer -->
    <footer id="footer" class="footer">
        <div class="copyright">
            &copy; Copyright <strong><span>A&D</span></strong>. All Rights Reserved
        </div>
        <div class="credits">
            Designed by <strong>A&D Team</strong>
        </div>
    </footer>

    <a href="#" class="back-to-top" id="backToTop">
        <i class="bi bi-arrow-up-short"></i>
    </a>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Toggle sidebar
        document.getElementById('toggleSidebarBtn').addEventListener('click', function () {
            document.body.classList.toggle('toggle-sidebar');
        });

        // Back to top
        window.addEventListener('scroll', function () {
            const backToTop = document.getElementById('backToTop');
            if (window.scrollY > 100) {
                backToTop.classList.add('active');
            } else {
                backToTop.classList.remove('active');
            }
        });

        document.getElementById('backToTop')?.addEventListener('click', function (e) {
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
