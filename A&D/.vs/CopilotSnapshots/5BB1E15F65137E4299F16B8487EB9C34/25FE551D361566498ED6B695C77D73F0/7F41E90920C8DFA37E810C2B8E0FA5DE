@model IEnumerable<A_D.Models.Milk>

@{
    ViewData["Title"] = "Danh Sách Sản Phẩm";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title">Danh Sách Sản Phẩm</h5>
            <a href="@Url.Action("Create", "Home", new { area = "Admin" })" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Thêm Mới
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i> Không có sản phẩm nào.
                <a href="@Url.Action("Create", "Home", new { area = "Admin" })">Thêm sản phẩm mới</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th scope="col">ID</th>
                            <th scope="col">Tên Sữa</th>
                            <th scope="col">Hãng</th>
                            <th scope="col">Trọng Lượng</th>
                            <th scope="col">Giá</th>
                            <th scope="col">Tồn Kho</th>
                            <th scope="col">Hạn SD</th>
                            <th scope="col">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <th scope="row">@item.MilkId</th>
                                <td>@item.MilkName</td>
                                <td><span class="badge bg-info">@item.Brand</span></td>
                                <td>@item.Weight</td>
                                <td><span class="badge bg-success">@string.Format("{0:N0}", item.Price) đ</span></td>
                                <td>
                                    @if (item.StockQuantity < 5)
                                    {
                                        <span class="badge bg-danger">@item.StockQuantity</span>
                                    }
                                    else if (item.StockQuantity < 10)
                                    {
                                        <span class="badge bg-warning">@item.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@item.StockQuantity</span>
                                    }
                                </td>
                                <td>@item.ExpiryDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a href="@Url.Action("Edit", "Home", new { area = "Admin", id = item.MilkId })" 
                                       class="btn btn-warning btn-sm" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", "Home", new { area = "Admin", id = item.MilkId })" 
                                       class="btn btn-danger btn-sm" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
