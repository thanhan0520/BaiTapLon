using Microsoft.AspNetCore.Mvc;
using A_D.Models;
using System.Linq;

namespace A_D.Areas.Admin.Controllers
{
    [Area("Admin")]
    public class HomeController : Controller
    {
        private readonly QuanLiBanSuaContext _context;
        private const int PageSize = 10;

        public HomeController(QuanLiBanSuaContext context)
        {
            _context = context;
        }

        // Kiểm tra quyền Admin
        private bool CheckAdminAccess()
        {
            var role = HttpContext.Session.GetString("Role");
            return role != null && role.ToLower() == "admin";
        }

        // GET: Admin/Home
        public IActionResult Index()
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            var totalProducts = _context.Milk.Count();
            var totalValue = _context.Milk.Sum(m => m.Price * m.StockQuantity);
            var lowStockProducts = _context.Milk.Where(m => m.StockQuantity < 5).Count();

            ViewBag.TotalProducts = totalProducts;
            ViewBag.TotalValue = totalValue;
            ViewBag.LowStockProducts = lowStockProducts;

            return View();
        }

        // GET: Admin/Home/Dashboard - Danh sách sản phẩm với tìm kiếm & phân trang
        public IActionResult dashBoard(string searchTerm, int page = 1)
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            var query = _context.Milk.AsQueryable();

            // Tìm kiếm
            if (!string.IsNullOrEmpty(searchTerm))
            {
                query = query.Where(m => m.MilkName.Contains(searchTerm) || m.Brand.Contains(searchTerm));
                ViewBag.SearchTerm = searchTerm;
            }

            // Phân trang
            var totalRecords = query.Count();
            var totalPages = (int)Math.Ceiling((double)totalRecords / PageSize);
            var milkList = query.OrderByDescending(m => m.MilkId)
                                .Skip((page - 1) * PageSize)
                                .Take(PageSize)
                                .ToList();

            ViewBag.Page = page;
            ViewBag.TotalPages = totalPages;
            ViewBag.TotalRecords = totalRecords;

            return View(milkList);
        }

        // GET: Admin/Home/Create
        public IActionResult Create()
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            return View();
        }

        // POST: Admin/Home/Create
        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Create(Milk milk)
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            if (ModelState.IsValid)
            {
                try
                {
                    _context.Milk.Add(milk);
                    _context.SaveChanges();
                    TempData["SuccessMessage"] = "Thêm sản phẩm thành công!";
                    return RedirectToAction(nameof(dashBoard));
                }
                catch (Exception ex)
                {
                    ModelState.AddModelError("", "Lỗi khi thêm sản phẩm: " + ex.Message);
                }
            }
            return View(milk);
        }

        // GET: Admin/Home/Edit/5
        public IActionResult Edit(int? id)
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            if (id == null)
            {
                return NotFound();
            }

            var milk = _context.Milk.Find(id);
            if (milk == null)
            {
                return NotFound();
            }
            return View(milk);
        }

        // POST: Admin/Home/Edit/5
        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Edit(int id, Milk milk)
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            if (id != milk.MilkId)
            {
                return NotFound();
            }

            if (ModelState.IsValid)
            {
                try
                {
                    _context.Update(milk);
                    _context.SaveChanges();
                    TempData["SuccessMessage"] = "Cập nhật sản phẩm thành công!";
                    return RedirectToAction(nameof(dashBoard));
                }
                catch (Exception ex)
                {
                    ModelState.AddModelError("", "Lỗi khi cập nhật: " + ex.Message);
                }
            }
            return View(milk);
        }

        // GET: Admin/Home/Delete/5
        public IActionResult Delete(int? id)
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            if (id == null)
            {
                return NotFound();
            }

            var milk = _context.Milk.Find(id);
            if (milk == null)
            {
                return NotFound();
            }
            return View(milk);
        }

        // POST: Admin/Home/Delete/5
        [HttpPost, ActionName("Delete")]
        [ValidateAntiForgeryToken]
        public IActionResult DeleteConfirmed(int id)
        {
            if (!CheckAdminAccess())
                return RedirectToAction("Login", "User", new { area = "" });

            var milk = _context.Milk.Find(id);
            if (milk != null)
            {
                try
                {
                    _context.Milk.Remove(milk);
                    _context.SaveChanges();
                    TempData["SuccessMessage"] = "Xóa sản phẩm thành công!";
                }
                catch (Exception ex)
                {
                    TempData["ErrorMessage"] = "Lỗi khi xóa: " + ex.Message;
                }
            }
            return RedirectToAction(nameof(dashBoard));
        }
    }
}