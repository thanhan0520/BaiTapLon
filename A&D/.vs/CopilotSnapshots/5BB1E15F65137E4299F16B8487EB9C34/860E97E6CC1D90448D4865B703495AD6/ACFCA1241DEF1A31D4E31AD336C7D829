@model A_D.Models.Milk

@{
    ViewData["Title"] = "Sửa Sản Phẩm";
}

<div class="row">
    <div class="col-md-8">
        <h1 class="mb-4">
            <i class="fas fa-edit"></i> @ViewData["Title"]
        </h1>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Cập Nhật Thông Tin Sản Phẩm</h5>
            </div>
            <div class="card-body">
                <form method="post" novalidate>
                    <input type="hidden" name="MilkId" value="@Model.MilkId" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="MilkName">Tên Sữa <span class="text-danger">*</span></label>
                            <input type="text" id="MilkName" name="MilkName" class="form-control @(ModelState.ContainsKey("MilkName") && !ModelState.IsValidField("MilkName") ? "is-invalid" : "")" 
                                   value="@Model.MilkName" placeholder="Nhập tên sản phẩm" required />
                            @if (ModelState.ContainsKey("MilkName") && !ModelState.IsValidField("MilkName"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.MilkName)
                                </div>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="Brand">Hãng <span class="text-danger">*</span></label>
                            <input type="text" id="Brand" name="Brand" class="form-control @(ModelState.ContainsKey("Brand") && !ModelState.IsValidField("Brand") ? "is-invalid" : "")" 
                                   value="@Model.Brand" placeholder="Nhập tên hãng" required />
                            @if (ModelState.ContainsKey("Brand") && !ModelState.IsValidField("Brand"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.Brand)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="Weight">Trọng Lượng <span class="text-danger">*</span></label>
                            <input type="text" id="Weight" name="Weight" class="form-control @(ModelState.ContainsKey("Weight") && !ModelState.IsValidField("Weight") ? "is-invalid" : "")" 
                                   value="@Model.Weight" placeholder="VD: 200ml, 1kg" required />
                            @if (ModelState.ContainsKey("Weight") && !ModelState.IsValidField("Weight"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.Weight)
                                </div>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="Price">Giá <span class="text-danger">*</span></label>
                            <input type="number" id="Price" name="Price" class="form-control @(ModelState.ContainsKey("Price") && !ModelState.IsValidField("Price") ? "is-invalid" : "")" 
                                   value="@Model.Price" placeholder="0" step="0.01" min="0" required />
                            @if (ModelState.ContainsKey("Price") && !ModelState.IsValidField("Price"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.Price)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="StockQuantity">Số Lượng Tồn <span class="text-danger">*</span></label>
                            <input type="number" id="StockQuantity" name="StockQuantity" class="form-control @(ModelState.ContainsKey("StockQuantity") && !ModelState.IsValidField("StockQuantity") ? "is-invalid" : "")" 
                                   value="@Model.StockQuantity" placeholder="0" min="0" required />
                            @if (ModelState.ContainsKey("StockQuantity") && !ModelState.IsValidField("StockQuantity"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.StockQuantity)
                                </div>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="ExpiryDate">Hạn Sử Dụng <span class="text-danger">*</span></label>
                            <input type="date" id="ExpiryDate" name="ExpiryDate" class="form-control @(ModelState.ContainsKey("ExpiryDate") && !ModelState.IsValidField("ExpiryDate") ? "is-invalid" : "")" 
                                   value="@Model.ExpiryDate.ToString("yyyy-MM-dd")" required />
                            @if (ModelState.ContainsKey("ExpiryDate") && !ModelState.IsValidField("ExpiryDate"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.ExpiryDate)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="ImagePath">Đường Dẫn Ảnh (Tuỳ Chọn)</label>
                        <input type="text" id="ImagePath" name="ImagePath" class="form-control" value="@Model.ImagePath" placeholder="/images/milk-product.jpg" />
                    </div>

                    @if (ModelState.ContainsKey("") && !ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle"></i> Vui lòng kiểm tra lại dữ liệu nhập vào.
                        </div>
                    }

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="@Url.Action("dashBoard", "Home", new { area = "Admin" })" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Cập Nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
