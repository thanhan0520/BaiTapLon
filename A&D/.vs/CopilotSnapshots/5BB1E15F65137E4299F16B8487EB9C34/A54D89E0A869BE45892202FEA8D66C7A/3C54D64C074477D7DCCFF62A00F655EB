@model A_D.Models.Milk

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

<div class="row">
    <div class="col-md-8">
        <h1 class="mb-4">
            <i class="fas fa-plus-circle"></i> @ViewData["Title"]
        </h1>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Thông Tin Sản Phẩm</h5>
            </div>
            <div class="card-body">
                <form method="post" novalidate>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="MilkName">Tên Sữa <span class="text-danger">*</span></label>
                            <input type="text" id="MilkName" name="MilkName" class="form-control @(ViewData.ModelState.ContainsKey("MilkName") && !ViewData.ViewData.ModelState.IsValidField("MilkName") ? "is-invalid" : "")" 
                                   placeholder="Nhập tên sản phẩm" required />
                            @if (ViewData.ModelState.ContainsKey("MilkName") && !ViewData.ModelState.IsValid)
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.MilkName)
                                </div>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="Brand">Hãng <span class="text-danger">*</span></label>
                            <input type="text" id="Brand" name="Brand" class="form-control @(ViewData.ModelState.ContainsKey("Brand") && !ViewData.ViewData.ViewData.ModelState.IsValidField("Brand") ? "is-invalid" : "")" 
                                   placeholder="Nhập tên hãng" required />
                            @if (ViewData.ModelState.ContainsKey("Brand") && !ViewData.ModelState.IsValidField("Brand"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.Brand)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="Weight">Trọng Lượng <span class="text-danger">*</span></label>
                            <input type="text" id="Weight" name="Weight" class="form-control @(ViewData.ViewData.ViewData.ModelState.ContainsKey("Weight") && !ViewData.ViewData.ViewData.ModelState.IsValidField("Weight") ? "is-invalid" : "")" 
                                   placeholder="VD: 200ml, 1kg" required />
                            @if (ViewData.ViewData.ViewData.ModelState.ContainsKey("Weight") && !ViewData.ViewData.ViewData.ModelState.IsValidField("Weight"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.Weight)
                                </div>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="Price">Giá <span class="text-danger">*</span></label>
                            <input type="number" id="Price" name="Price" class="form-control @(ViewData.ModelState.ContainsKey("Price") && !ViewData.ViewData.ViewData.ModelState.IsValidField("Price") ? "is-invalid" : "")" 
                                   placeholder="0" step="0.01" min="0" required />
                            @if (ViewData.ViewData.ViewData.ModelState.ContainsKey("Price") && !ViewData.ViewData.ViewData.ModelState.IsValidField("Price"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.Price)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="StockQuantity">Số Lượng Tồn <span class="text-danger">*</span></label>
                            <input type="number" id="StockQuantity" name="StockQuantity" class="form-control @(ViewData.ViewData.ModelState.ContainsKey("StockQuantity") && !ViewData.ViewData.ModelState.IsValidField("StockQuantity") ? "is-invalid" : "")" 
                                   placeholder="0" min="0" required />
                            @if (ViewData.ViewData.ModelState.ContainsKey("StockQuantity") && !ViewData.ViewData.ModelState.IsValidField("StockQuantity"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.StockQuantity)
                                </div>
                            }
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label" for="ExpiryDate">Hạn Sử Dụng <span class="text-danger">*</span></label>
                            <input type="date" id="ExpiryDate" name="ExpiryDate" class="form-control @(ViewData.ViewData.ModelState.ContainsKey("ExpiryDate") && !ViewData.ViewData.ModelState.IsValidField("ExpiryDate") ? "is-invalid" : "")" required />
                            @if (ViewData.ViewData.ModelState.ContainsKey("ExpiryDate") && !ViewData.ViewData.ModelState.IsValidField("ExpiryDate"))
                            {
                                <div class="invalid-feedback d-block">
                                    @Html.ValidationMessageFor(m => m.ExpiryDate)
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="ImagePath">Đường Dẫn Ảnh (Tuỳ Chọn)</label>
                        <input type="text" id="ImagePath" name="ImagePath" class="form-control" placeholder="/images/milk-product.jpg" />
                    </div>

                    @if (ViewData.ViewData.ModelState.ContainsKey("") && !ViewData.ViewData.ViewData.ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle"></i> Vui lòng kiểm tra lại dữ liệu nhập vào.
                        </div>
                    }

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="@Url.Action("dashBoard", "Home", new { area = "Admin" })" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Lưu Sản Phẩm
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
