@model IEnumerable<Milk>

<style>
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fafc);
    }

    .product-wrapper {
        max-width: 1400px;
        margin: auto;
    }

    .col-custom {
        width: 20%;
    }

    @@media (max-width: 1200px) {
        .col-custom {
            width: 25%;
        }
    }

    @@media (max-width: 992px) {
        .col-custom {
            width: 33.33%;
        }
    }

    @@media (max-width: 768px) {
        .col-custom {
            width: 50%;
        }
    }

    @@media (max-width: 480px) {
        .col-custom {
            width: 100%;
        }
    }

    .product-card {
        border-radius: 16px;
        transition: all 0.3s ease;
        background: white;
        border: none;
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        }

    .img-box {
        width: 100%;
        aspect-ratio: 1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        padding: 10px;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 12px;
        transition: 0.3s;
    }

    .product-card:hover .product-img {
        transform: scale(1.05);
    }

    .badge {
        border-radius: 10px;
        padding: 5px 8px;
        font-size: 0.75rem;
    }

    .price {
        font-size: 1rem;
        font-weight: bold;
        color: #dc2626;
    }

    .stock {
        font-size: 0.85rem;
    }

    .btn-add {
        border-radius: 10px;
        font-size: 0.9rem;
        padding: 6px;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        border: none;
        transition: 0.3s;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(99,102,241,0.4);
        }

    .section-title {
        font-weight: 700;
        color: #4f46e5;
    }

    .card-body {
        padding: 12px;
    }

    .product-name {
        font-size: 0.95rem;
        min-height: 40px;
    }
</style>

<div class="container mt-5 product-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title">Sản phẩm gợi ý</h2>
    </div>

    <div class="d-flex flex-wrap">
        @foreach (var item in Model)
        {
            <div class="col-custom p-2">
                <div class="card product-card h-100">

                    <div class="img-box">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" class="product-img" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center w-100 h-100">
                                Không có ảnh
                            </div>
                        }
                    </div>

                    <div class="card-body d-flex flex-column">

                        <div class="product-name fw-semibold mb-1">
                            @item.MilkName
                        </div>

                        <div class="mb-1">
                            <span class="badge bg-secondary">@item.Brand</span>
                        </div>

                        <div class="text-muted small mb-1">
                            @item.Weight
                        </div>

                        <div class="price mb-1">
                            @String.Format("{0:N0}", item.Price) đ
                        </div>

                        <div class="text-muted stock mb-2">
                            Còn: @item.StockQuantity
                        </div>

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-auto">
                            <input type="hidden" name="id" value="@item.MilkId" />
                            <button type="submit" class="btn btn-add w-100">
                                Thêm
                            </button>
                        </form>

                    </div>

                </div>
            </div>
        }
    </div>
</div>