@{
    ViewData["Title"] = "Chỉnh Sửa Hồ Sơ";
    Layout = "~/Areas/Administrator/Views/Shared/_Layout.cshtml";
}

<style>
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-header {
        background: white;
        padding: 30px;
        border-radius: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        text-align: center;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 0;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 20px;
        overflow: hidden;
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .profile-avatar.has-image {
        background: none;
    }

    .profile-avatar.has-image i {
        display: none;
    }

    .profile-name {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 10px 0;
        color: #333;
    }

    .profile-role {
        color: #666;
        font-size: 0.95rem;
    }

    .profile-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        border-bottom: 1px solid #e5e7eb;
        background: white;
        padding: 0 20px;
        border-radius: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .profile-tabs a {
        padding: 15px 20px;
        text-decoration: none;
        color: #666;
        border-bottom: 3px solid transparent;
        transition: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .profile-tabs a:hover {
        color: #6366f1;
    }

    .profile-tabs a.active {
        color: #6366f1;
        border-bottom-color: #6366f1;
    }

    .profile-content {
        background: white;
        padding: 30px;
        border-radius: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 0;
        font-size: 1rem;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .image-upload-section {
        grid-column: 1 / -1;
        padding: 20px;
        background: #f9fafb;
        border: 1px dashed #d1d5db;
        border-radius: 0;
        text-align: center;
        margin-bottom: 20px;
    }

    .profile-image-preview {
        width: 150px;
        height: 150px;
        border-radius: 0;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 20px;
        object-fit: cover;
        overflow: hidden;
        flex-shrink: 0;
    }

    .profile-image-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        background: none;
    }

    .profile-image-preview i {
        color: white;
    }

    .upload-input-label {
        display: inline-block;
        background: #6366f1;
        color: white;
        padding: 12px 30px;
        border-radius: 0;
        cursor: pointer;
        transition: none;
        margin-bottom: 10px;
        font-weight: 500;
    }

    .upload-input-label:hover {
        background: #4f46e5;
    }

    #imageFile {
        display: none;
    }

    .upload-description {
        color: #666;
        font-size: 0.9rem;
        margin-top: 10px;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px solid #e5e7eb;
    }

    .btn-submit {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        padding: 12px 30px;
        border: none;
        border-radius: 0;
        text-decoration: none;
        cursor: pointer;
        transition: none;
        flex: 1;
        font-weight: 600;
    }

    .btn-submit:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .btn-cancel {
        background: #e5e7eb;
        color: #333;
        padding: 12px 30px;
        border: none;
        border-radius: 0;
        text-decoration: none;
        cursor: pointer;
        transition: none;
        flex: 1;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .profile-tabs {
            flex-direction: column;
        }
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar" id="profileHeaderAvatar">
            <i class="bi bi-person"></i>
        </div>
        <div class="profile-name" id="profileHeaderName">Admin User</div>
        <div class="profile-role">Quản Trị Viên</div>
    </div>

    <div class="profile-tabs">
        <a href="/Administrator/Profile/Overview">
            <i class="bi bi-person"></i>
            <span>Tổng Quan</span>
        </a>
        <a href="/Administrator/Profile/Edit" class="active">
            <i class="bi bi-pencil"></i>
            <span>Chỉnh Sửa</span>
        </a>
        <a href="/Administrator/Profile/Settings">
            <i class="bi bi-gear"></i>
            <span>Cài Đặt</span>
        </a>
        <a href="/Administrator/Profile/ChangePassword">
            <i class="bi bi-key"></i>
            <span>Mật Khẩu</span>
        </a>
    </div>

    <div class="profile-content">
        <h2>Chỉnh Sửa Hồ Sơ</h2>

        <form method="post" enctype="multipart/form-data">
            <div class="image-upload-section">
                <div id="imagePreview" class="profile-image-preview">
                    <i class="bi bi-person"></i>
                </div>
                <label for="imageFile" class="upload-input-label">
                    <i class="bi bi-cloud-upload"></i> Chọn Ảnh Profile
                </label>
                <input type="file" id="imageFile" name="profileImage" accept="image/*">
                <div class="upload-description">
                    <p>JPG, PNG hoặc GIF. Kích thước tối đa 5MB.</p>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Tên Đăng Nhập</label>
                    <input type="text" name="username" value="admin" readonly>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" value="admin@example.com" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Tên Đầy Đủ</label>
                    <input type="text" name="fullname" value="Admin User" required>
                </div>
                <div class="form-group">
                    <label>Số Điện Thoại</label>
                    <input type="tel" name="phone" value="">
                </div>
            </div>

            <div class="form-group">
                <label>Địa Chỉ</label>
                <input type="text" name="address" value="">
            </div>

            <div class="action-buttons">
                <button type="submit" class="btn-submit">Lưu Thay Đổi</button>
                <a href="/Administrator/Profile/Overview" class="btn-cancel">Hủy</a>
            </div>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const imageFileInput = document.getElementById('imageFile');
        const imagePreview = document.getElementById('imagePreview');
        const profileHeaderAvatar = document.getElementById('profileHeaderAvatar');
        const profileHeaderName = document.getElementById('profileHeaderName');

        // Load profile image and name from server-side session
        const profileImage = '@Html.Raw(Context.Session.GetString("AdminProfileImage") ?? "")';
        const adminFullName = '@Html.Raw(Context.Session.GetString("AdminFullName") ?? "Admin User")';

        // Update header avatar and name
        if (profileImage) {
            const img = document.createElement('img');
            img.src = profileImage;
            img.alt = 'Profile';
            img.style.width = '100%';
            img.style.height = '100%';
            img.style.objectFit = 'cover';
            profileHeaderAvatar.innerHTML = '';
            profileHeaderAvatar.appendChild(img);
            profileHeaderAvatar.classList.add('has-image');
        }

        if (adminFullName && adminFullName !== 'Admin User') {
            profileHeaderName.textContent = adminFullName;
        }

        // Update image preview with uploaded image from server if exists
        if (profileImage) {
            const img = document.createElement('img');
            img.src = profileImage;
            img.style.width = '100%';
            img.style.height = '100%';
            img.style.objectFit = 'cover';
            imagePreview.innerHTML = '';
            imagePreview.appendChild(img);
        }

        // Handle file selection and preview
        imageFileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                // Validate file type
                const allowedTypes = ['image/jpeg', 'image/png', 'image/gif'];
                if (!allowedTypes.includes(file.type)) {
                    alert('Vui lòng chọn file ảnh hợp lệ (JPG, PNG, GIF)');
                    this.value = '';
                    return;
                }

                // Validate file size (5MB)
                if (file.size > 5 * 1024 * 1024) {
                    alert('Ảnh quá lớn. Kích thước tối đa là 5MB.');
                    this.value = '';
                    return;
                }

                // Create preview
                const reader = new FileReader();
                reader.onload = function(event) {
                    const img = document.createElement('img');
                    img.src = event.target.result;
                    img.style.width = '100%';
                    img.style.height = '100%';
                    img.style.objectFit = 'cover';

                    imagePreview.innerHTML = '';
                    imagePreview.appendChild(img);
                };
                reader.readAsDataURL(file);
            }
        });
    });
</script>