<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>@ViewData["Title"] - Admin Quản Lý Bán Sữa</title>
    <meta content="" name="description">
    <meta content="" name="keywords">

    <!-- Bootstrap CSS -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #eef2ff, #f8fafc);
            font-family: 'Segoe UI', sans-serif;
        }

        .admin-container {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 250px;
            background: linear-gradient(180deg, #4f46e5, #6366f1);
            color: white;
            padding: 20px 0;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .admin-sidebar .brand {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            margin-bottom: 20px;
        }

        .admin-sidebar .brand h3 {
            font-size: 1.3rem;
            margin: 0;
        }

        .admin-sidebar .nav-menu {
            list-style: none;
        }

        .admin-sidebar .nav-menu li {
            padding: 0;
        }

        .admin-sidebar .nav-menu a {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            color: white;
            text-decoration: none;
            transition: all 0.3s;
            border-left: 4px solid transparent;
        }

        .admin-sidebar .nav-menu a:hover {
            background: rgba(255,255,255,0.1);
            border-left-color: white;
        }

        .admin-sidebar .nav-menu a.active {
            background: rgba(255,255,255,0.2);
            border-left-color: white;
        }

        .admin-sidebar .nav-menu i {
            margin-right: 12px;
            font-size: 1.2rem;
        }

        .admin-main {
            margin-left: 250px;
            width: calc(100% - 250px);
            padding: 20px;
        }

        .admin-header {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .admin-header h1 {
            font-size: 1.5rem;
            margin: 0;
            color: #333;
        }

        .user-menu {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .user-menu a, .user-menu button {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s;
        }

        .user-menu a:hover, .user-menu button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(99,102,241,0.3);
        }

        .admin-content {
            background: white;
            border-radius: 0;
            padding: 25px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        @@media (max-width: 768px) {
            .admin-sidebar {
                width: 200px;
            }

            .admin-main {
                margin-left: 200px;
                width: calc(100% - 200px);
            }

            .admin-header {
                flex-direction: column;
                gap: 15px;
                align-items: flex-start;
            }
        }

        @@media (max-width: 576px) {
            .admin-sidebar {
                width: 100%;
                height: auto;
                position: relative;
            }

            .admin-main {
                margin-left: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="admin-container">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="brand">
                <h3>🥛 Admin Panel</h3>
                <small>Quản Lý Bán Sữa</small>
            </div>

            <ul class="nav-menu">
                <li>
                    <a href="/Administrator/Home/Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="/Administrator/Milk/Index">
                        <i class="bi bi-box"></i>
                        <span>Sản Phẩm</span>
                    </a>
                </li>
                <li>
                    <a href="/Administrator/Order/Index">
                        <i class="bi bi-bag-check"></i>
                        <span>Đơn Hàng</span>
                    </a>
                </li>
                <li>
                    <a href="/Administrator/User/Index">
                        <i class="bi bi-people"></i>
                        <span>Người Dùng</span>
                    </a>
                </li>
                <hr style="border-color: rgba(255,255,255,0.2); margin: 15px 0;">
                <li>
                    <a href="/">
                        <i class="bi bi-house"></i>
                        <span>Về Trang Chủ</span>
                    </a>
                </li>
                <li>
                    <a href="/User/Logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Đăng Xuất</span>
                    </a>
                </li>
            </ul>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <div class="admin-header">
                <h1>@ViewData["Title"]</h1>
                <div class="user-menu">
                    <span>Xin chào, Admin!</span>
                </div>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["FailMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["FailMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="admin-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
