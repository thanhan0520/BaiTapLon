@model IEnumerable<Order>

@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
    Layout = "~/Areas/Administrator/Views/Shared/_Layout.cshtml";
}

<style>
    .order-container {
        padding: 20px;
    }

    .order-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .order-table thead {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
    }

    .order-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
    }

    .order-table td {
        padding: 15px;
        border-bottom: 1px solid #f0f0f0;
    }

    .order-table tbody tr:hover {
        background: #f9fafb;
    }

    .status-badge {
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .status-pending {
        background: #fef3c7;
        color: #b45309;
    }

    .status-processing {
        background: #dbeafe;
        color: #1e40af;
    }

    .status-completed {
        background: #dcfce7;
        color: #166534;
    }

    .status-cancelled {
        background: #fee2e2;
        color: #991b1b;
    }

    .btn-details {
        background: #4f46e5;
        color: white;
        padding: 6px 12px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

    .btn-details:hover {
        background: #4338ca;
        color: white;
    }

    .amount-badge {
        background: #ecfdf5;
        color: #047857;
        padding: 5px 10px;
        border-radius: 20px;
        font-weight: 600;
    }
</style>

<div class="order-container">
    <h1>📋 Quản Lý Đơn Hàng</h1>

    @if (Model.Any())
    {
        <table class="order-table">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Khách Hàng</th>
                    <th>Ngày Đặt</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng Thái</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><strong>#@order.OrderId</strong></td>
                        <td>@order.User?.UserName</td>
                        <td>@order.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><span class="amount-badge">@order.TotalAmount?.ToString("N0") ₫</span></td>
                        <td>
                            @{
                                var statusClass = order.OrderStatus?.ToLower() switch
                                {
                                    "pending" => "status-pending",
                                    "processing" => "status-processing",
                                    "completed" => "status-completed",
                                    "cancelled" => "status-cancelled",
                                    _ => "status-pending"
                                };
                            }
                            <span class="status-badge @statusClass">@order.OrderStatus</span>
                        </td>
                        <td>
                            <a href="/Administrator/Order/Details/@order.OrderId" class="btn-details">Chi Tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 40px;">
            <h3>Không có đơn hàng nào</h3>
        </div>
    }
</div>
