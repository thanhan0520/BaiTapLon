@{
    ViewData["Title"] = "Admin - Dashboard";
    Layout = "~/Areas/Administrator/Views/Shared/_Layout.cshtml";
}

<style>
    .dashboard-container {
        padding: 20px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        text-align: center;
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.15);
    }

    .stat-number {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6366f1;
        margin: 10px 0;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .admin-menu {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
        margin-top: 30px;
    }

    .admin-link {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        padding: 20px;
        border-radius: 10px;
        text-decoration: none;
        text-align: center;
        transition: all 0.3s ease;
        font-weight: 600;
    }

    .admin-link:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(99,102,241,0.3);
        color: white;
    }
</style>

<div class="dashboard-container">
    <h1 class="mb-4">🏠 Dashboard Quản Lý</h1>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">📦 Sản Phẩm</div>
            <div class="stat-number">@(ViewBag.TotalProducts ?? 0)</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">👥 Người Dùng</div>
            <div class="stat-number">@(ViewBag.TotalUsers ?? 0)</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">📋 Đơn Hàng</div>
            <div class="stat-number">@(ViewBag.TotalOrders ?? 0)</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">💰 Doanh Thu</div>
            <div class="stat-number">@(ViewBag.TotalRevenue ?? 0)</div>
        </div>
    </div>

    <h3>Quản Lý</h3>
    <div class="admin-menu">
        <a href="/Administrator/Milk/Index" class="admin-link">Sản Phẩm</a>
        <a href="/Administrator/Order/Index" class="admin-link">Đơn Hàng</a>
        <a href="/Administrator/User/Index" class="admin-link">Người Dùng</a>
    </div>
</div>
