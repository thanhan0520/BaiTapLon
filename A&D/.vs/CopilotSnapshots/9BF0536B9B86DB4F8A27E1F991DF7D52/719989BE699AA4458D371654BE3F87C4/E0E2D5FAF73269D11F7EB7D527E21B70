@model IEnumerable<User>

@{
    ViewData["Title"] = "Quản Lý Người Dùng";
    Layout = "~/Areas/Administrator/Views/Shared/_Layout.cshtml";
}

<style>
    .user-container {
        padding: 20px;
    }

    .user-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 0;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .user-table thead {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
    }

    .user-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
    }

    .user-table td {
        padding: 15px;
        border-bottom: 1px solid #f0f0f0;
    }

    .user-table tbody tr:hover {
        background: #f9fafb;
    }

    .role-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .role-admin {
        background: #fecaca;
        color: #991b1b;
    }

    .role-customer {
        background: #bfdbfe;
        color: #1e40af;
    }

    .btn-details {
        background: #4f46e5;
        color: white;
        padding: 6px 12px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

    .btn-details:hover {
        background: #4338ca;
        color: white;
    }
</style>

<div class="user-container">
    <h1>👥 Quản Lý Người Dùng</h1>

    @if (Model.Any())
    {
        <table class="user-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên Đăng Nhập</th>
                    <th>Email</th>
                    <th>Vai Trò</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td><strong>@user.UserId</strong></td>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>
                            @{
                                var roleClass = (user.Role?.ToLower() ?? "customer") switch
                                {
                                    "admin" => "role-admin",
                                    _ => "role-customer"
                                };
                                var roleDisplay = (user.Role?.ToLower() ?? "customer") switch
                                {
                                    "admin" => "Quản Trị",
                                    _ => "Khách Hàng"
                                };
                            }
                            <span class="role-badge @roleClass">@roleDisplay</span>
                        </td>
                        <td>
                            <a href="/Administrator/User/Details/@user.UserId" class="btn-details">Chi Tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="text-align: center; padding: 40px;">
            <h3>Không có người dùng nào</h3>
        </div>
    }
</div>
