@{
    ViewData["Title"] = "Thay Đổi Mật Khẩu";
    Layout = "~/Areas/Administrator/Views/Shared/_Layout.cshtml";
}

<style>
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-header {
        background: white;
        padding: 30px;
        border-radius: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        text-align: center;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 0;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 20px;
    }

    .profile-name {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 10px 0;
        color: #333;
    }

    .profile-role {
        color: #666;
        font-size: 0.95rem;
    }

    .profile-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        border-bottom: 1px solid #e5e7eb;
        background: white;
        padding: 0 20px;
        border-radius: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .profile-tabs a {
        padding: 15px 20px;
        text-decoration: none;
        color: #666;
        border-bottom: 3px solid transparent;
        transition: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .profile-tabs a:hover {
        color: #6366f1;
    }

    .profile-tabs a.active {
        color: #6366f1;
        border-bottom-color: #6366f1;
    }

    .profile-content {
        background: white;
        padding: 30px;
        border-radius: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        max-width: 600px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .form-group input {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 0;
        font-size: 1rem;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    .form-group input:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }

    .password-hint {
        font-size: 0.85rem;
        color: #666;
        margin-top: 5px;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px solid #e5e7eb;
    }

    .btn-submit {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        padding: 12px 30px;
        border: none;
        border-radius: 0;
        text-decoration: none;
        cursor: pointer;
        transition: none;
        flex: 1;
        font-weight: 600;
    }

    .btn-submit:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .btn-cancel {
        background: #e5e7eb;
        color: #333;
        padding: 12px 30px;
        border: none;
        border-radius: 0;
        text-decoration: none;
        cursor: pointer;
        transition: none;
        flex: 1;
        font-weight: 600;
    }

    .security-tips {
        background: #f0f9ff;
        border-left: 4px solid #0ea5e9;
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 0;
    }

    .security-tips h4 {
        color: #0369a1;
        margin: 0 0 10px 0;
        font-size: 0.95rem;
    }

    .security-tips ul {
        margin: 0;
        padding-left: 20px;
        color: #0369a1;
        font-size: 0.9rem;
    }

    .security-tips li {
        margin-bottom: 5px;
    }

    @@media (max-width: 768px) {
        .profile-tabs {
            flex-direction: column;
        }
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        <div class="profile-avatar">
            <i class="bi bi-person"></i>
        </div>
        <div class="profile-name">Admin User</div>
        <div class="profile-role">Quản Trị Viên</div>
    </div>

    <div class="profile-tabs">
        <a href="/Administrator/Profile/Overview">
            <i class="bi bi-person"></i>
            <span>Tổng Quan</span>
        </a>
        <a href="/Administrator/Profile/Edit">
            <i class="bi bi-pencil"></i>
            <span>Chỉnh Sửa</span>
        </a>
        <a href="/Administrator/Profile/Settings">
            <i class="bi bi-gear"></i>
            <span>Cài Đặt</span>
        </a>
        <a href="/Administrator/Profile/ChangePassword" class="active">
            <i class="bi bi-key"></i>
            <span>Mật Khẩu</span>
        </a>
    </div>

    <div class="profile-content">
        <h2>Thay Đổi Mật Khẩu</h2>
        
        <div class="security-tips">
            <h4><i class="bi bi-shield-check"></i> Mẹo Bảo Mật</h4>
            <ul>
                <li>Sử dụng mật khẩu mạnh với ít nhất 8 ký tự</li>
                <li>Kết hợp chữ hoa, chữ thường, số và ký tự đặc biệt</li>
                <li>Không sử dụng thông tin cá nhân trong mật khẩu</li>
                <li>Thay đổi mật khẩu định kỳ</li>
            </ul>
        </div>

        <form method="post">
            <div class="form-group">
                <label>Mật Khẩu Hiện Tại</label>
                <input type="password" name="currentPassword" required placeholder="Nhập mật khẩu hiện tại">
            </div>

            <div class="form-group">
                <label>Mật Khẩu Mới</label>
                <input type="password" name="newPassword" required placeholder="Nhập mật khẩu mới">
                <div class="password-hint">Tối thiểu 8 ký tự, bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt</div>
            </div>

            <div class="form-group">
                <label>Xác Nhận Mật Khẩu Mới</label>
                <input type="password" name="confirmPassword" required placeholder="Nhập lại mật khẩu mới">
            </div>

            <div class="action-buttons">
                <button type="submit" class="btn-submit">Cập Nhật Mật Khẩu</button>
                <a href="/Administrator/Profile/Overview" class="btn-cancel">Hủy</a>
            </div>
        </form>
    </div>
</div>
