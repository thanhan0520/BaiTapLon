@model LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập";
}

<style>
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fafc);
    }

    .login-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        border-radius: 20px;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .login-header {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        padding: 20px;
        text-align: center;
    }

        .login-header h3 {
            margin: 0;
            font-weight: 600;
        }

    .form-control {
        border-radius: 10px;
        padding: 10px;
        transition: 0.2s;
        border: 1px solid #e5e7eb;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
        }

    .form-check-input {
        cursor: pointer;
    }

    .btn-login {
        border-radius: 12px;
        padding: 10px;
        font-weight: 600;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        border: none;
        transition: 0.3s;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(99,102,241,0.4);
        }

    .login-footer a {
        color: #4f46e5;
        text-decoration: none;
        font-weight: 500;
    }

        .login-footer a:hover {
            text-decoration: underline;
        }

    .alert {
        border-radius: 10px;
        font-size: 0.9rem;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">

        <div class="login-header">
            <h3>Đăng Nhập</h3>
        </div>

        <div class="p-4">

            <form asp-action="Login" asp-controller="User" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" placeholder="Nhập tên đăng nhập" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-login">
                        Đăng Nhập
                    </button>
                </div>
            </form>

            <div class="login-footer mt-3 text-center">
                <p class="mb-0">
                    Chưa có tài khoản?
                    <a asp-action="Register" asp-controller="User">Đăng ký ngay</a>
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}