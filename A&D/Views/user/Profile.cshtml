@model A_D.Models.User

@{
    ViewData["Title"] = "Hồ sơ cá nhân";

    var adminProfileImage = Context.Session.GetString("AdminProfileImage");
    var avatarImage = !string.IsNullOrWhiteSpace(adminProfileImage)
        ? adminProfileImage
        : Url.Content("~/image/canh.jpg");
}

<style>
    body {
        background: linear-gradient(135deg, #eef2ff, #f8fafc);
    }

    .profile-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .profile-card {
        width: 100%;
        max-width: 420px;
        border-radius: 20px;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
        text-align: center;
        padding: 25px;
    }

    /* AVATAR */
    .avatar-box {
        width: 140px;
        height: 140px;
        margin: auto;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #6366f1;
        box-shadow: 0 5px 20px rgba(0,0,0,0.15);
    }

        .avatar-box img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* giữ đẹp ảnh 1536x2048 */
        }

    .username {
        font-size: 1.3rem;
        font-weight: 600;
        margin-top: 15px;
    }

    .badge-role {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        padding: 6px 12px;
        border-radius: 10px;
        font-weight: 500;
    }

    .info-box {
        text-align: left;
        margin-top: 15px;
    }

        .info-box p {
            margin-bottom: 10px;
            font-size: 0.95rem;
        }

        .info-box strong {
            color: #374151;
        }

    .btn-logout {
        margin-top: 15px;
        border-radius: 12px;
        padding: 10px;
        font-weight: 600;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border: none;
        transition: 0.3s;
    }

        .btn-logout:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(239,68,68,0.4);
        }

    hr {
        margin: 20px 0;
    }
</style>

<div class="profile-wrapper">
    <div class="profile-card">

        <!-- AVATAR -->
        <div class="avatar-box">
            <img src="@avatarImage" alt="Avatar" />
        </div>

        <div class="username">@Model.UserName</div>

        <span class="badge badge-role mb-3">
            @(Model.Role ?? "User")
        </span>

        <hr />

        <div class="info-box">
            <p>
                <strong>Tên đăng nhập:</strong> @Model.UserName
            </p>
            <p>
                <strong>Email:</strong> @Model.Email
            </p>
            <p>
                <strong>Vai trò:</strong> @(Model.Role ?? "User")
            </p>
        </div>

        <hr />

        <a href="/User/Logout" class="btn btn-logout w-100">
            Đăng xuất
        </a>

    </div>
</div>